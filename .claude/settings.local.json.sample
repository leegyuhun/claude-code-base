{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); f=d.get('tool_input',{}).get('file_path',''); blocked=f.endswith(('.pas','.dfm')); print('[CP949] Write tool blocked on .pas/.dfm - use Edit tool or Python cp949 method') if blocked else None; sys.exit(2 if blocked else 0)\"",
            "statusMessage": "CP949 파일 보호 검사 중..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); f=d.get('tool_input',{}).get('file_path',''); warn=f.endswith(('.pas','.dfm')); print('[CP949 WARNING] Edit on .pas/.dfm detected. Ensure old_string/new_string boundaries do NOT include Korean characters. Use Python cp949 method for Korean comments.') if warn else None; sys.exit(0)\"",
            "statusMessage": "CP949 Edit 경고 검사 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretooluse-bash-guard.sh",
            "statusMessage": "Bash 위험 명령 검사 중..."
          }
        ]
      }
    ]
  },
  "env": {
    "GITLAB_TOKEN": "<GITLAB_TOKEN>",
    "REDMINE_URL": "https://redmine.ubware.com",
    "REDMINE_API_KEY": "<REDMINE_API_KEY>"
  },
  "enabledMcpjsonServers": [
    "gitlab",
    "redmine"
  ]
}
