#!/bin/bash
# YSR EMR 커밋 메시지 형식 검사
#
# 형식: {타입}: {설명}
# 예시:
#   feat: [sprint-02] 기능명 요약
#   fix: 핫픽스 설명
#
# 규칙 (dev-process.md §7):
#   - feat: | fix: | refactor: | chore: | docs: | test: 중 하나로 시작
#   - 제목 요약과 본문은 한글로 작성 (코드 식별자·브랜치명은 영문 유지)

MSG_FILE="$1"
FIRST_LINE=$(head -1 "$MSG_FILE")

# Merge / Revert / 자동 생성 커밋 건너뜀
if echo "$FIRST_LINE" | grep -qE "^(Merge |Revert |Co-Authored-By:)"; then
  exit 0
fi

# 형식 검사: {타입}[({scope})]: {내용}
if ! echo "$FIRST_LINE" | grep -qE "^(feat|fix|refactor|chore|docs|test|style|perf|build|ci)(\(.+\))?: .+"; then
  echo ""
  echo "❌ 커밋 메시지 형식 오류"
  echo ""
  echo "  현재  : $FIRST_LINE"
  echo ""
  echo "  형식  : {타입}: {설명}"
  echo "  예시  : feat: [sprint-02] 기능명 요약"
  echo "         fix: 핫픽스 설명"
  echo ""
  echo "  타입  : feat | fix | refactor | chore | docs | test | style | perf"
  echo ""
  echo "  ※ 제목·본문은 한글로 작성 (함수명·브랜치명은 영문 유지)"
  echo ""
  exit 1
fi

exit 0
